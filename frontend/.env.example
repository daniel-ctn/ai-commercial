# ─────────────────────────────────────────────────────────────
# Frontend Environment Configuration
# ─────────────────────────────────────────────────────────────

# The URL of the backend API (FastAPI or NestJS)
# In local development: http://localhost:8000/api/v1 (FastAPI) or http://localhost:8001/api/v1 (NestJS)
# In production, set this to your deployed backend URL.
VITE_API_URL=http://localhost:8000/api/v1

# Example placeholder for any other client-side keys (like analytics or chat UI tracking)
# VITE_ANALYTICS_ID=placeholder